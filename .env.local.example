# ─── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # Keep secret — never expose to browser

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...                          # or sk_test_... for testing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...         # or pk_test_...

# Dashboard → Developers → Webhooks → Add endpoint
# Endpoint URL: https://your-domain.vercel.app/api/stripe/webhook
# Events to listen for: checkout.session.completed, customer.subscription.*
STRIPE_WEBHOOK_SECRET=whsec_...

# Dashboard → Products → Create two recurring prices
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...

# ─── Finnhub ──────────────────────────────────────────────────────────────────
# https://finnhub.io → Dashboard → API Key (free tier: 60 req/min)
FINNHUB_API_KEY=your_finnhub_key_here

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Any random secret string — used to authenticate Vercel Cron's requests to
# app/api/cron/*. Must also be set in Vercel → Project → Settings →
# Environment Variables so the scheduled jobs (daily ticker metrics, monthly
# rankings) can actually run.
CRON_SECRET=your_random_secret_here

# ─── Resend (newsletter) ───────────────────────────────────────────────────────
# https://resend.com → API Keys. Powers the monthly Top 25 newsletter and Pro
# watchlist digest (app/api/cron/send-newsletter). Free tier: 3,000 emails/mo.
RESEND_API_KEY=re_your_key_here
# The "from" address must be on a domain verified in Resend.
NEWSLETTER_FROM_EMAIL=newsletter@ownfolio.net

# ─── App ──────────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL (no trailing slash)
# Also add this in Vercel Dashboard → Project → Settings → Environment Variables
NEXT_PUBLIC_APP_URL=https://signalfolio.net
